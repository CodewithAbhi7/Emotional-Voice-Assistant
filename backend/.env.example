GEMINI_API_KEY=your_key_here

DEBUG=true
HOST=0.0.0.0
PORT=8000

DB_PATH=./data/eva.db
VOICE_SAMPLES_DIR=./data/voice_samples
SPEAKER_PROFILES_DIR=./data/speaker_profiles
PHRASE_CACHE_DIR=./data/phrase_cache

VOICE_PROVIDER=chatterbox
CHATTERBOX_BASE_URL=http://127.0.0.1:4123
CHATTERBOX_TIMEOUT_SEC=240
CHATTERBOX_EXAGGERATION=0.55
CHATTERBOX_CFG_WEIGHT=0.50
CHATTERBOX_TEMPERATURE=0.80
VOICE_PROFILE_SAMPLE_RATE=24000

WHISPER_MODEL=base

ALARM_SNOOZE_MINUTES=1
ALARM_MAX_ESCALATIONS=3
ALARM_ESCALATION_TRIGGER=2

GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_FLASH_MODEL=gemini-2.5-flash
